# Slack App credentials — copy to .env and fill in values
# Get these from https://api.slack.com/apps after creating your app

SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token   # Required for Socket Mode

# Port for HTTP mode (ignored in Socket Mode)
PORT=3000
