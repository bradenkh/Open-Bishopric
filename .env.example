# Supabase (client-side — safe to expose, protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-side only — NEVER expose. Bypasses RLS.)
# Used for the AI agent's data access and inviting bishopric members.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres connection string (deploy/CI only — used by `npm run db:reset`).
# Settings → Database → Connection string → Session pooler (IPv4, required for Vercel).
# postgresql://postgres.[REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# AI Provider
# The AI assistant is configured in-app under Settings → AI assistant (stored in
# the database), so these env vars are OPTIONAL — they're only used as a fallback
# for any field left blank in Settings. Leave them empty to manage everything
# from the UI.
#   AI_PROVIDER: "deepseek" for DeepSeek, or "openai-compat" for Z.AI (GLM).
#   AI_BASE_URL: only used for openai-compat (Z.AI default: https://open.bigmodel.cn/api/paas/v4/).
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
AI_BASE_URL=
