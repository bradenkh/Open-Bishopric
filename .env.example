# Supabase (client-side — safe to expose, protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-side only — NEVER expose. Bypasses RLS.)
# Used for the AI agent's data access and inviting bishopric members.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres connection string (deploy/CI only — used by `npm run db:reset`).
# Settings → Database → Connection string → Session pooler (IPv4, required for Vercel).
# postgresql://postgres.[REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# AI Provider
# Set AI_PROVIDER to "deepseek" for DeepSeek, or leave blank for Z.AI (GLM via OpenAI-compat)
AI_PROVIDER=openai-compat
AI_API_KEY=
AI_MODEL=glm-4-flash
# Only needed for openai-compat (Z.AI default):
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
